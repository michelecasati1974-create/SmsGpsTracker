<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- INTERVAL -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Intervallo invio (ms)"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tempo tra un SMS e il successivo" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(cammino 240000; bici 120000; auto 60000)"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edtInterval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number" />

        <!-- DISTANCE -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Distanza minima (m)"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scarta punti troppo vicini" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(cammino 8; bici 15; auto 30)"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edtDistance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number" />

        <!-- ANGLE -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Angolo minimo (°)"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Elimina micro variazioni direzione" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(cammino 5; bici 8; auto 12)"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edtAngle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal" />

        <!-- EPSILON -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Precisione (epsilon)"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Compressione traiettoria" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(cammino 0.00005; bici 0.0001; auto 0.00015)"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edtEpsilon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal" />

        <!-- MIN POINTS -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Min punti"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Numero minimo punti per invio" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(cammino 5; bici 8; auto 10)"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edtMinPoints"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number" />

        <!-- KEEP -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rolling buffer (keep)"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Punti mantenuti dopo invio" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(cammino 2; bici 3; auto 3)"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edtKeep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number" />

        <!-- SAVE -->

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SALVA"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</ScrollView>